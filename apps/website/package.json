{
  "name": "website",
  "description": "Run code snippets in any programming language with student.codes!",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "prebuild": "sayable extract && sayable compile",
    "build": "use-env -p NEXT -P -- next build --no-lint",
    "postbuild": "use-env -p NEXT -P -- next-sitemap --config sitemap.config.ts",
    "start": "use-env -p NEXT -P -- next start",
    "dev": "use-env -p NEXT -- next dev --turbo"
  },
  "dependencies": {
    "@codemirror/commands": "^6.9.0",
    "@codemirror/view": "^6.38.6",
    "@evaluate/components": "workspace:^",
    "@evaluate/hooks": "workspace:^",
    "@evaluate/logger": "workspace:^",
    "@evaluate/style": "workspace:^",
    "@hookform/resolvers": "^5.2.2",
    "@sayable/react": "0.0.0-alpha.8",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@uiw/codemirror-extensions-langs": "^4.25.2",
    "@uiw/codemirror-theme-vscode": "^4.25.2",
    "@uiw/react-codemirror": "^4.25.2",
    "@vercel/speed-insights": "^1.2.0",
    "date-fns": "^4.1.0",
    "discord-bot": "workspace:^",
    "dompurify": "^3.4.11",
    "embla-carousel-autoplay": "^8.6.0",
    "es-toolkit": "^1.40.0",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.1.0",
    "is-mobile": "^5.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "material-icon-theme": "^5.27.0",
    "next": "15.5.18",
    "next-themes": "npm:@wits/next-themes@^0.2.16",
    "piston.ts": "workspace:^",
    "posthog-js": "^1.276.0",
    "react": "^19.2.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.65.0",
    "react-hotkeys-hook": "^5.2.1",
    "sayable": "0.0.0-alpha.6",
    "server-only": "^0.0.1",
    "sharp": "^0.34.4",
    "tailwind-merge": "^3.3.1",
    "type-fest": "^5.1.0",
    "virtual-file-explorer-backend": "workspace:^",
    "vscode-icons-js": "^11.6.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@million/lint": "^1.0.14",
    "@next/bundle-analyzer": "15.5.6",
    "@sayable/config": "0.0.0-alpha.4",
    "@sayable/factory": "0.0.0-alpha.6",
    "@sayable/format-po": "0.0.0-alpha.4",
    "@sayable/swc-plugin": "0.0.0-alpha.5",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.7",
    "autoprefixer": "^10.4.21",
    "next-sitemap": "^4.2.3",
    "tailwindcss": "^4.1.14"
  }
}
